# =============================================================================
# Required for production (Vercel → Project → Settings → Environment Variables)
# Never commit real values. No hardcoded fallbacks in code.
# =============================================================================

# Owner / Admin auth (required for production; owner login disabled if missing)
OWNER_EMAIL=
OWNER_PASSWORD=
OWNER_SECURITY_ANSWER=
JWT_SECRET=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs — Chapter I (5 t-shirts). Use your Stripe Dashboard IDs.
STRIPE_PRICE_ISOLE_CAYMAN=
STRIPE_PRICE_ISOLA_DI_NECKER=
STRIPE_PRICE_MONROES_KISSES=
STRIPE_PRICE_SARDINIA=
STRIPE_PRICE_PORT_COTON=

# Site URL (redirects, images)
SITE_URL=

# Optional: test user email for 0€ checkout (when logged in with this email)
# TEST_USER_EMAIL=

# Resend: order confirmation + verification emails (required for order-confirmed emails)
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=   (e.g. noreply@yourdomain.com or onboarding@resend.dev)
# SUPPORT_EMAIL=       (reply-to for order emails; default: support@sandrosandri.com)
# RESEND_API_KEY_PROD= / RESEND_API_KEY_PREVIEW= (alternate keys)

# Optional: CORS / app URL
# ALLOWED_ORIGIN= / APP_URL=
